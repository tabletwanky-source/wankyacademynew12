{
  "entities": {
    "student": {
      "title": "Student",
      "description": "A registered student at Wanky Academy",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "studentCode": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "dateOfBirth": { "type": "string" },
        "photoURL": { "type": "string" },
        "course": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "studentCode", "fullName", "email", "course", "createdAt"]
    },
    "course": {
      "title": "Course",
      "description": "Available courses at Wanky Academy",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "counter": {
      "title": "Counter",
      "description": "Sequential counters for student code generation",
      "type": "object",
      "properties": {
        "count": { "type": "integer" }
      },
      "required": ["count"]
    },
    "admin": {
      "title": "Admin",
      "description": "System administrators",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["uid", "email", "role"]
    },
    "teacher": {
      "title": "Teacher",
      "description": "Academy instructors",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "course": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["fullName", "email", "course"]
    },
    "payment": {
      "title": "Payment",
      "description": "Student payment records",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentCode": { "type": "string" },
        "amount": { "type": "number" },
        "paymentType": { "type": "string", "enum": ["Registration", "Installment", "Full"] },
        "paymentDate": { "type": "string", "format": "date-time" },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Pending", "Partial"] },
        "remainingBalance": { "type": "number" }
      },
      "required": ["studentId", "amount", "paymentType", "paymentStatus"]
    },
    "courseModule": {
      "title": "Course Module",
      "description": "A collection of lessons within a course",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "integer" },
        "description": { "type": "string" }
      },
      "required": ["courseId", "title", "order"]
    },
    "lesson": {
      "title": "Lesson",
      "description": "An individual learning unit",
      "type": "object",
      "properties": {
        "moduleId": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "lessonType": { "type": "string", "enum": ["video", "pdf"] },
        "lessonURL": { "type": "string" },
        "duration": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["moduleId", "courseId", "title", "lessonType", "lessonURL"]
    },
    "attendance": {
      "title": "Attendance",
      "description": "Student attendance records",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentCode": { "type": "string" },
        "courseId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Present", "Absent", "Late"] },
        "markedBy": { "type": "string" }
      },
      "required": ["studentId", "courseId", "date", "status"]
    },
    "schedule": {
      "title": "Schedule",
      "description": "Course class schedule",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "days": { "type": "array", "items": { "type": "string" } },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "teacherId": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["courseId", "days", "startTime", "endTime"]
    },
    "exam": {
      "title": "Exam",
      "description": "Assessment metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "courseId": { "type": "string" },
        "duration": { "type": "integer" },
        "passingScore": { "type": "integer" },
        "totalQuestions": { "type": "integer" },
        "published": { "type": "boolean" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "courseId", "duration", "passingScore"]
    },
    "question": {
      "title": "Question",
      "description": "Individual exam item",
      "type": "object",
      "properties": {
        "examId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["mcq", "boolean", "short"] },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "string" },
        "points": { "type": "integer" }
      },
      "required": ["examId", "text", "type", "correctAnswer"]
    },
    "examResult": {
      "title": "Exam Result",
      "description": "Student performance record",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "examId": { "type": "string" },
        "score": { "type": "integer" },
        "totalPoints": { "type": "integer" },
        "percentage": { "type": "number" },
        "passed": { "type": "boolean" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "examId", "score", "passed"]
    },
    "examAttempt": {
      "title": "Exam Attempt",
      "description": "Real-time progress saving",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "examId": { "type": "string" },
        "answers": { "type": "object" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "examId"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "student",
      "description": "Main students collection"
    },
    "/courses/{courseId}": {
      "schema": "course",
      "description": "Available courses info"
    },
    "/counters/{courseId}": {
      "schema": "counter",
      "description": "Internal counters for ID generation"
    },
    "/admins/{adminId}": {
      "schema": "admin",
      "description": "Administrators with system access"
    },
    "/teachers/{teacherId}": {
      "schema": "teacher",
      "description": "Faculty and staff"
    },
    "/payments/{paymentId}": {
      "schema": "payment",
      "description": "Financial transaction history"
    },
    "/courseModules/{moduleId}": {
      "schema": "courseModule",
      "description": "Curriculum sections"
    },
    "/lessons/{lessonId}": {
      "schema": "lesson",
      "description": "Educational content units"
    },
    "/attendance/{attendanceId}": {
      "schema": "attendance",
      "description": "Daily presence tracking"
    },
    "/schedules/{scheduleId}": {
      "schema": "schedule",
      "description": "Time table records"
    },
    "/exams/{examId}": {
      "schema": "exam",
      "description": "Exam metadata"
    },
    "/questions/{questionId}": {
      "schema": "question",
      "description": "Exam questions"
    },
    "/examResults/{resultId}": {
      "schema": "examResult",
      "description": "Student outcomes"
    },
    "/examAttempts/{attemptId}": {
      "schema": "examAttempt",
      "description": "In-progress session data"
    }
  }
}
