rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'NuntZgcpKibzUsW2ESmTd8TJPg72' ||
        (request.auth.token.email != null && (
          request.auth.token.email.lower() == 'wankyacademy@gmail.com' ||
          request.auth.token.email.lower() == 'wankychat3@gmail.com' ||
          request.auth.token.email.lower() == 'admin@wankyacademy.com' ||
          request.auth.token.email.lower() == 'preacherwan@gmail.com'
        )) ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid))) ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') == 'admin')
      );
    }

    // --- Stats & Analytics ---
    match /stats/{id} {
      allow read, list: if isAdmin();
      allow write: if isAdmin();
    }

    // --- global whitelist ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    function isProfessor() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none') == 'professor') ||
        (request.auth.token.email != null && request.auth.token.email.lower().endsWith('@professor.wanky.com'))
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- Collection Rules ---

    // Unified Users Collection
    match /users/{uid} {
      allow read: if isSignedIn();
      allow list: if isAdmin() || isProfessor();
      allow create: if isAdmin(); // Only admins create users via API usually, but this is a fallback
      allow update: if isAdmin() || isOwner(uid);
      allow delete: if isAdmin();
    }

    // Assigned Exams
    match /assignedExams/{assignmentId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }

    // Students Collection
    match /students/{studentId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isProfessor());
      allow write: if isAdmin() || isProfessor() || (isSignedIn() && request.resource.data.userId == request.auth.uid);
    }

    // Student Codes Mapping
    match /studentCodes/{code} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Exams
    match /exams/{examId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }

    // Questions
    match /questions/{questionId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }

    // Exam Results
    match /examResults/{resultId} {
      allow read: if isAdmin() || isProfessor() || (isSignedIn() && (resource == null || resource.data.studentId == request.auth.uid));
      allow list: if isAdmin() || isProfessor() || (isSignedIn() && (resource == null || resource.data.studentId == request.auth.uid)); 
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Exam Attempts (Progress)
    match /examAttempts/{attemptId} {
      allow read, write, delete: if isSignedIn() && (attemptId.split('_')[0] == request.auth.uid || isAdmin() || isProfessor());
    }

    // Video Classes
    match /videos/{videoId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }

    // Homework Assignments
    match /homework/{homeworkId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }

    match /homeworks/{homeworkId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin() || isProfessor();
    }

    // Attendance
    match /attendance/{attendanceId} {
      allow read, list: if isSignedIn();
      allow create: if isAdmin() || isProfessor();
      allow update, delete: if isAdmin();
    }

    // Homework Submissions
    match /homeworkSubmissions/{submissionId} {
      allow read, list: if isAdmin() || isProfessor() || (isSignedIn() && (resource == null || resource.data.studentUid == request.auth.uid));
      allow create: if isSignedIn();
      allow update: if isAdmin() || isProfessor();
      allow delete: if isAdmin();
    }

    // Video Learning System
    match /videos/{videoId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isProfessor();
    }

    match /videoComments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isProfessor() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /videoProgress/{progressId} {
      allow read: if isSignedIn() && (isAdmin() || isProfessor() || resource.data.studentUid == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || isProfessor() || resource.data.studentUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Blog / Articles System
    match /articles/{articleId} {
      allow read: if (resource.data.published == true && resource.data.status == 'published') || isAdmin() || isProfessor();
      allow create, update, delete: if isAdmin() || isProfessor();
    }

    match /articleComments/{commentId} {
      allow read: if true; // Publicly readable
      allow create: if true; // Publicly allow for now, ideally restrict to signed in or use a flag
      allow update, delete: if isAdmin() || isProfessor() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /articleLikes/{likeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Legacy Submissions (Fallback)
    match /submissions/{submissionId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isProfessor();
      allow delete: if isAdmin();
    }

    // Payments
    match /payments/{paymentId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Financial Records
    match /financialRecords/{recordId} {
      allow read: if isAdmin() || (isSignedIn() && (recordId == 'record_' + request.auth.uid || (resource != null && resource.data.studentUid == request.auth.uid)));
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // Counters (Internal)
    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // System Settings (Global configurations)
    match /systemSettings/{docId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Security Monitoring & Logs
    match /securityLogs/{id} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Platform Backups
    match /backups/{id} {
      allow read, write, list: if isAdmin();
    }

    // WA Multi-Services
    match /serviceRequests/{requestId} {
      allow create: if true; // Public can create
      allow read, list, update, delete: if isAdmin(); // Only admin can manage
    }

    // Certificates
    match /certificates/{certId} {
      allow read, list: if true; // Public verification allowed
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Historical Certificates
    match /oldCertificates/{certId} {
      allow read, list: if true; // Public verification allowed
      allow write: if isAdmin();
    }

    // Badges
    match /badges/{badgeId} {
      allow read, list: if true; // Public verification allowed as requested
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Financial Settings
    match /financialSettings/{settingId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Student Payments
    match /studentPayments/{paymentId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Receipts
    match /receipts/{receiptId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}

